        "    random_state=42,\n",
        "    n_jobs=-1,                 # Use all CPU cores\n",
        "    eval_metric='logloss'      # Explicit evaluation metric to avoid warnings\n",
        ")\n",
        "\n",
        "# Train model using raw features and sample weights\n",
