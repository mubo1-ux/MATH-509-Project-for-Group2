        "# Added a tiny epsilon (1e-10) to prevent division by zero warnings.\n",
        "epsilon = 1e-10\n",
        "f1_scores = 2 * (precisions[:-1] * recalls[:-1]) / (precisions[:-1] + recalls[:-1] + epsilon)\n",
        "\n",
        "# ==========================================\n",
        "# 3. Identify the Best Threshold\n",
        "# ==========================================\n",
        "best_idx = np.argmax(f1_scores)\n",
